# ============================================================================
# kluris pack — environment configuration
#
# Copy this file to .env and fill in the values for your setup:
#     cp .env.example .env
#
# The server reads these once at boot. After editing, restart the container
# (docker compose down && docker compose up -d) to apply changes. Secrets
# stay on this host — they are never logged (the config redacts them to ***).
# ============================================================================


# ════════════════════════════════════════════════════════════════════════════
# 1. AUTH  (REQUIRED) — pick EXACTLY ONE path: API-key OR OAuth.
#    Setting vars from both paths makes the server fail fast at boot.
# ════════════════════════════════════════════════════════════════════════════

# ─── API-key path ───────────────────────────────────────────────────────────
# Anthropic-style OR OpenAI-style endpoint. The two shapes share the same four
# vars — only the values differ. Pick ONE shape.

# -- Anthropic shape (default) --
KLURIS_PROVIDER_SHAPE=anthropic
KLURIS_BASE_URL=https://api.anthropic.com
KLURIS_API_KEY=sk-replace-me
KLURIS_MODEL=claude-opus-4-7

# -- OpenAI shape (uncomment this block; comment out the Anthropic one above) --
# Works with OpenAI and any OpenAI-compatible gateway (OpenRouter, Azure
# OpenAI, vLLM, ...). Set BASE_URL to the host root only — kluris appends the
# endpoint path itself.
#
# Routing: when BASE_URL is api.openai.com, kluris talks to OpenAI's Responses
# API (/v1/responses) — that is what lets gpt-5.x reasoning models use
# KLURIS_REASONING_EFFORT together with the agent's tools (see section 2). Every
# other (gateway) host stays on Chat Completions (/v1/chat/completions).
# KLURIS_PROVIDER_SHAPE=openai
# KLURIS_BASE_URL=https://api.openai.com
# KLURIS_API_KEY=sk-replace-me
# KLURIS_MODEL=gpt-5.4-mini

# ─── OAuth client_credentials path ──────────────────────────────────────────
# Use this instead of the API-key block when fronting an internal company
# gateway with OAuth 2.0. The gateway must speak the OpenAI Chat Completions
# shape. KLURIS_MODEL (above) is still required.
# KLURIS_OAUTH_TOKEN_URL=https://idp.example.com/token
# KLURIS_OAUTH_API_BASE_URL=https://gateway.example.com
# KLURIS_OAUTH_CLIENT_ID=kluris-app
# KLURIS_OAUTH_CLIENT_SECRET=oauth-secret-here
# KLURIS_OAUTH_SCOPE=read:llm          # optional


# ════════════════════════════════════════════════════════════════════════════
# 2. MODEL / AGENT TUNABLES  (optional — recommended values shown)
# ════════════════════════════════════════════════════════════════════════════
#
# ─── COST / TOKEN TUNING — READ THIS FIRST ──────────────────────────────────
# A broad question ("rate for X across ALL countries") makes the agent call
# tools over several rounds, and EACH round re-sends the running transcript to
# the model — so INPUT-token cost grows with the number of rounds. One turn can
# cost hundreds of thousands of tokens if the model keeps re-searching. Three
# knobs dominate that cost. Below are two BOUNDED presets — both fix the usual
# runaway (unlimited rounds); pick by how much you value synthesis depth:
#
#   BEST QUALITY  (recommended — rounds + keep ship at these values)
#       MAX_AGENT_ROUNDS=12  ·  KEEP_RESULT_ROUNDS=3  ·  REASONING_EFFORT=high
#     Bounds the runaway WITHOUT touching answer depth. 12 rounds at high effort
#     is effectively indistinguishable from UNLIMITED in answer quality — with
#     the 2.28 tools a well-tooled broad query reaches its evidence in far fewer
#     rounds — while cutting worst-case cost roughly in half. Start here.
#     (Effort ships at the model default; set REASONING_EFFORT=high yourself on
#      the OpenAI shape — the Anthropic default ignores it. See section 2.)
#
#   CHEAPEST  (trade a little synthesis depth for ~a third more off the bill)
#       MAX_AGENT_ROUNDS=12  ·  KEEP_RESULT_ROUNDS=2  ·  REASONING_EFFORT=medium
#     `medium` is the ONE real quality tradeoff: fine for retrieval-style "find
#     X and report it" questions, weaker on hard cross-source synthesis. A/B it
#     on YOUR real questions before committing.
#
# Of the three, MAX_AGENT_ROUNDS is the #1 lever — 0 (UNLIMITED) is the usual
# runaway, so change it first; the agent still answers from what it gathered
# when it hits the cap. REASONING_EFFORT is the ONLY knob that trades answer
# quality for cost; KEEP_RESULT_ROUNDS just bounds per-round re-send size.
# ────────────────────────────────────────────────────────────────────────────

# Anthropic API version header (Anthropic shape only).
KLURIS_ANTHROPIC_VERSION=2023-06-01

# Max iterations of the tool-calling loop per user turn — the SINGLE BIGGEST
# lever on cost. Each round is one LLM round-trip plus a tool dispatch (~1-3s),
# and every round re-sends the growing transcript, so cost scales with rounds.
# With the 2.28.0 tools a broad question resolves in 1-2 searches
# (group_by_lobe returns the top hits per lobe; full_bodies returns content in
# one call), so ~12 is plenty for genuine cross-cutting questions. Set to 0 for
# UNLIMITED — NOT recommended on a metered provider: a model that keeps
# re-searching with reworded queries can burn hundreds of thousands of input
# tokens on ONE turn. At the cap the agent still produces a final answer from
# everything it gathered.
MAX_AGENT_ROUNDS=12

# Hard ceiling on the TOTAL tool calls in one turn — a backstop the round cap
# can't provide: a single round can emit MANY parallel tool calls, so 12 rounds
# can still make 30+ calls if the model fans out (e.g. one search per lobe on an
# "X across all lobes" question). 0 = off (default). Set a value to bound the
# worst case; at the cap the agent stops calling tools and answers from what it
# gathered. ~40 is generous headroom over what a well-tooled turn needs.
# KLURIS_MAX_TOOL_CALLS=40

# Byte budget for the lobe_overview tool's JSON-encoded payload.
# Clamped to [1024, 16384].
KLURIS_LOBE_OVERVIEW_BUDGET=4096

# Max paths per multi_read call. Clamped to [1, 20].
KLURIS_MAX_MULTI_READ_PATHS=5

# Per-response output token budget — the model's answer-length cap. kluris
# sends the unified max_tokens; LiteLLM maps it per provider (e.g. to
# max_completion_tokens for OpenAI reasoning models). Raise it for long answers,
# or for reasoning models that spend output tokens on hidden reasoning before
# answering. Clamped to [16, 200000].
KLURIS_MAX_OUTPUT_TOKENS=4096

# Sampling temperature. Leave UNSET (commented out) to use the model's own
# default — required for some reasoning models that reject an explicit
# temperature. Set 0.0 for the most deterministic answers; clamped to [0.0,
# 2.0] when provided.
# KLURIS_TEMPERATURE=0.0

# Reasoning effort for OpenAI-shape reasoning models, sent as `reasoning_effort`.
# On OpenAI proper (KLURIS_BASE_URL=https://api.openai.com) kluris routes through
# the Responses API, so gpt-5.x reasoning models — INCLUDING gpt-5.4-mini —
# accept reasoning effort TOGETHER WITH the agent's tools; this knob just works
# there. Accepted values are MODEL-DEPENDENT (none / minimal / low / medium /
# high / xhigh; each model takes a subset — low / medium / high are the common
# core, and the provider returns a 400 if it rejects the value you pick).
# OPENAI SHAPE ONLY (incl. the OAuth path); the Anthropic shape ignores it (the
# pack does not drive Anthropic adaptive thinking) and prints a boot warning if
# you set it there. On an OpenAI-compatible GATEWAY (non-OpenAI host) effort is
# honored only if that gateway accepts it on Chat Completions.
#
# COST vs QUALITY — this is the ONE knob that trades answer quality for cost.
# `high` is the most thorough (best cross-source synthesis) AND the most
# exploratory (it fans out into more searches); `medium` converges faster and
# cheaper and is plenty for retrieval-style "find X and report it" questions.
# On gpt-5.x the model's OWN default is already `medium`, so leaving this
# commented = the CHEAPEST preset. Uncomment and set `high` for the BEST-QUALITY
# preset (OpenAI shape only). Bounding MAX_AGENT_ROUNDS already captures most of
# the cost win, so prefer keeping `high` if answer quality matters to you.
# KLURIS_REASONING_EFFORT=high

# Force the OpenAI Responses API (/v1/responses) for a NON-OpenAI gateway host
# that genuinely implements it. Most gateways do NOT — leave this unset. When
# unset, only api.openai.com is routed through Responses; every other host uses
# Chat Completions. No effect on the Anthropic or OAuth paths.
# KLURIS_USE_RESPONSES_API=0

# Sliding-window budget (estimated tokens) for CONVERSATION HISTORY — the prior
# turns replayed to the model each message. Once the transcript exceeds this,
# the oldest turns are dropped so a long chat never hits the model's context
# limit (it just forgets its oldest turns; facts are re-fetched from the brain
# each turn). Set this BELOW your model's context window, leaving room for the
# system prompt, tool results, and the answer. 0 = unlimited (no trimming;
# very long chats may eventually error). Estimated at ~4 chars/token.
KLURIS_MAX_CONTEXT_TOKENS=24000

# Per-TURN request budget (estimated tokens). WITHIN one answer the agent calls
# tools over several rounds and re-sends every prior result each round; on a
# broad query that grows quadratically. When a turn's request would exceed this,
# the OLDEST tool results are elided (newest kept) to bound the cost. Distinct
# from MAX_CONTEXT_TOKENS (which trims cross-turn history). 0 = unlimited.
KLURIS_MAX_TURN_TOKENS=96000

# Per-neuron body cap (bytes) on the AGENT's read_neuron / multi_read calls, so a
# batch read of large files can't blow the turn budget; truncated bodies are
# flagged and the model is told to search for the specific section. The
# brain-explorer sidebar (human reader) is never clamped. 0 = unlimited.
KLURIS_MAX_NEURON_BYTES=16384

# In-turn evidence window (rounds). Tool results older than this many rounds
# are elided from the request — the model has already read them; the
# final-answer fallback always sees everything gathered, and re-issuing the
# exact call re-serves the full result. Keeps long research turns cheap well
# below MAX_TURN_TOKENS. 3 (the default, BEST-QUALITY preset) keeps a safe
# margin of recent evidence resident; drop to 2 for the CHEAPEST re-sends, or
# 0 to never elide eagerly.
KLURIS_KEEP_RESULT_ROUNDS=3


# ════════════════════════════════════════════════════════════════════════════
# 2b. ACCESS CONTROL & RETENTION  (optional, strongly recommended when exposed)
# ════════════════════════════════════════════════════════════════════════════
# Shared-secret gate for the whole app (everything except /healthz). When set,
# requests need the token via "Authorization: Bearer <token>", the
# kluris_access cookie, or a one-time "?token=<token>" URL (which sets the
# cookie — share http://host:8765/?token=... with your team and the browser
# just works). Unset = open server + a loud boot warning. ANY exposure beyond
# localhost should set this.
# KLURIS_ACCESS_TOKEN=

# Per-IP rate limit on POST /chat (requests/minute, fixed window, in-process).
# One chat turn can fan out into many provider calls — this is the backstop
# against a single client driving unbounded spend. 0 = disabled.
# KLURIS_RATE_LIMIT_PER_MIN=10

# Prune chat sessions older than N days at boot. 0 = keep forever (default —
# retention is opt-in; deleting history must never be a surprise).
# KLURIS_SESSION_RETENTION_DAYS=90

# Pin the system prompt at boot instead of re-reading
# /data/config/system_prompt.md per request. Live-editing stays the default;
# set 1 on hardened deployments so a write to the /data volume can't silently
# rewire the agent's behavior. (Prompt edits then need a container restart.)
# KLURIS_LOCK_SYSTEM_PROMPT=0


# ════════════════════════════════════════════════════════════════════════════
# 3. TLS for corporate / on-prem gateways  (optional)
# ════════════════════════════════════════════════════════════════════════════
# By default kluris uses the system CA bundle and verifies certificates. These
# two vars handle a self-signed cert or a certificate signed by a private
# internal CA. Set AT MOST ONE — they're mutually exclusive (boot fails fast
# if both are set).
#
# Secure option: point at a PEM bundle that includes your private root CA.
# Mount the file into the container as a volume in docker-compose if it lives
# outside the image. Boot HARD-FAILS if the file is missing.
# KLURIS_CA_BUNDLE=/data/corp-root-ca.pem
#
# Escape hatch: disable TLS verification entirely. Opt-in only — boot prints a
# loud warning so deployers can spot accidents in logs.
# KLURIS_TLS_INSECURE=0


# ════════════════════════════════════════════════════════════════════════════
# 4. BOOT SMOKE-TEST  (optional)
# ════════════════════════════════════════════════════════════════════════════
# By default kluris probes the LLM endpoint at startup with a tiny `ping` tool
# schema, so misconfigured gateways fail fast. Some corporate gateways don't
# return the standard chat-completions shape even when the chat itself works
# (Azure passthrough, batch-only proxies, custom envelopes). Set this to skip
# the boot probe; the first real chat is then the first endpoint hit. Boot
# prints a loud warning so deployers can spot accidents in logs.
# KLURIS_SKIP_BOOT_SMOKE=0
#
# Stream diagnostics: when set, the server writes ONE summary line per LLM
# stream to the container logs (`docker compose logs`) — chunk count, whether
# any text/tool-call surfaced, and the final finish_reason. Use it to diagnose
# an empty "the model returned no content for this turn" reply: the failing
# round is the last summary line before the error. No request/response payloads
# are logged, so it is safe to leave on — and far quieter than LITELLM_LOG=DEBUG.
# KLURIS_DEBUG_STREAM=0


# ════════════════════════════════════════════════════════════════════════════
# 5. CUSTOMIZATION THAT IS *NOT* AN ENV VAR  (worth knowing)
# ════════════════════════════════════════════════════════════════════════════
# • The brain is baked READ-ONLY into the Docker image at /app/brain. There is
#   no env var to relocate it and it cannot be edited at runtime — don't set a
#   brain path here. To ship updated brain content, re-run `kluris pack` and
#   rebuild the image. Chat history persists in the /data volume.
#
# • System prompt / research playbook — the biggest behavior lever.
#   Edit  /data/config/system_prompt.md  (created on first boot from the
#   bundled default). It is re-read on EVERY request, so changes take effect
#   live with no restart (unless KLURIS_LOCK_SYSTEM_PROMPT=1 pins it at boot).
#   This controls how the agent searches, cites sources, and when it stops —
#   tune it to your brain and audience.
#
# • Port / image name — edit docker-compose.yml, not .env:
#     - the port maps to 127.0.0.1:8765 by default (loopback only); change to
#       "0.0.0.0:8765:8765" for public exposure (put auth in front first).
#     - ${KLURIS_IMAGE} overrides the built image tag.
